{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "codegen": {
      "dependsOn": ["@corpdk/codegen-cli#build"],
      "inputs": ["src/**/*.ts", "prisma/schema.prisma", "drizzle/schema.ts"],
      "outputs": ["../ds-sdk/src/generated/**", "../ds-cli/src/generated/**"],
      "cache": true
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["generated/prisma/**"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": { "outputs": [] },
    "clean": { "cache": false }
  }
}
