{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@corpdk/ui-auth": ["./src/index.ts"],
      "@/*": ["./scaffold/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "scaffold/**/*.ts", "scaffold/**/*.tsx", "scaffold/**/*.d.ts"],
  "exclude": ["node_modules"]
}
