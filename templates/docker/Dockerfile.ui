# syntax=docker/dockerfile:1
# Requires output: 'standalone' in packages/UI_DIR/next.config.ts
# Build from the monorepo root: docker build -f packages/UI_DIR/Dockerfile .

# ── Base ──────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

# ── Deps ──────────────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/UI_DIR/package.json ./packages/UI_DIR/package.json

RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile

# ── Build ─────────────────────────────────────────────────────────────────────
FROM deps AS build
WORKDIR /app

COPY packages/UI_DIR ./packages/UI_DIR

# Public env vars must be available at build time
ARG NEXT_PUBLIC_DS_URL
ARG NEXT_PUBLIC_DS_WS_URL
ENV NEXT_PUBLIC_DS_URL=$NEXT_PUBLIC_DS_URL
ENV NEXT_PUBLIC_DS_WS_URL=$NEXT_PUBLIC_DS_WS_URL

RUN pnpm --filter @corpdk/UI_DIR build

# ── Runtime ───────────────────────────────────────────────────────────────────
# Next.js standalone output bundles the server — no pnpm or next CLI needed.
# In a pnpm monorepo, .next/standalone mirrors the workspace layout:
#   packages/UI_DIR/server.js  ← entry point after COPY --from=build standalone ./
FROM base AS runtime
WORKDIR /app
ENV NODE_ENV=production
ENV HOSTNAME="0.0.0.0"

COPY --from=build /app/packages/UI_DIR/.next/standalone ./
COPY --from=build /app/packages/UI_DIR/.next/static ./packages/UI_DIR/.next/static
COPY --from=build /app/packages/UI_DIR/public ./packages/UI_DIR/public

EXPOSE 3000
CMD ["node", "packages/UI_DIR/server.js"]
