{
  "name": "@corpdk/ds",
  "version": "2026.3.0-alpha.1",
  "type": "module",
  "publishConfig": {
    "registry": "https://artifactory.corp.example.com/api/npm/npm-private/"
  },
  "scripts": {
    "dev": "node --env-file .env --import tsx/esm --watch src/index.ts",
    "build": "tsc && cp -r src/schema dist/",
    "codegen": "graphql-codegen",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@corpdk/pub-sub": "workspace:*",
    "@graphql-yoga/redis-event-target": "^3.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "graphql": "^16.13.2",
    "zod": "^4.3.6",
    "graphql-ws": "^6.0.8",
    "graphql-yoga": "^5.18.1",
    "ioredis": "^5.10.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@corpdk/codegen-cli": "workspace:*",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-resolvers": "^5.1.7",
    "@types/node": "^20.19.37",
    "@types/ws": "^8.18.1",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
