// Prisma schema for @corpdk/ds
// Docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model Item {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?
  active      Boolean  @default(true)
  /// ISO-8601 timestamp stored as a string for cross-template consistency.
  createdAt   String
}
