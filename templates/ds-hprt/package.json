{
  "name": "@corpdk/ds-hprt",
  "version": "2026.3.0-alpha.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file .env --import tsx/esm --watch src/index.ts",
    "build": "tsc && cp -r src/schema dist/",
    "codegen": "graphql-codegen",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@corpdk/pub-sub": "workspace:*",
    "@graphql-yoga/redis-event-target": "^3.0.0",
    "drizzle-orm": "^0.44.2",
    "graphql": "^16.11.0",
    "zod": "^3.24.2",
    "graphql-ws": "^5.16.0",
    "graphql-yoga": "^5.13.4",
    "ioredis": "^5.0.0",
    "pg": "^8.16.3",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@corpdk/codegen-cli": "workspace:*",
    "@graphql-codegen/cli": "^5.0.5",
    "@graphql-codegen/client-preset": "^4.5.1",
    "@graphql-codegen/typescript": "^4.1.5",
    "@graphql-codegen/typescript-resolvers": "^4.5.1",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.11.14",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
